# Optional: persistent data directory (dbs, uploads, config)
# NOTES_DATA_DIR=/data

# Upload limits
# Attachment upload limit in MB (default: 50)
# VORTNOTES_ATTACHMENT_MAX_MB=50

# Legacy attachment upload override in GB (optional)
# VORTNOTES_ATTACHMENT_MAX_GB=

# Inline media (Quill image/video embeds) upload limit in MB (default: 50)
# VORTNOTES_INLINE_MEDIA_MAX_MB=50

# Legacy override: global request limit in MB (if set, overrides attachment cap)
# VORTNOTES_MAX_CONTENT_MB=

# If you terminate TLS at a reverse proxy and want secure cookies regardless of
# Flask seeing the request as HTTPS:
# VORTNOTES_FORCE_SECURE_COOKIES=1

# Optional direct HTTPS. Set both paths; in Docker, mount the files read-only.
# VORTNOTES_TLS_CERT_FILE=/certs/fullchain.pem
# VORTNOTES_TLS_KEY_FILE=/certs/privkey.pem

# Trust X-Forwarded-* headers from exactly one reverse proxy. Do not enable when
# VortNotes is directly exposed to clients.
# VORTNOTES_TRUST_PROXY_HEADERS=1

# Version reported by /healthz (normally injected by the release image).
# VORTNOTES_VERSION=1.0.0

# Optional first-run admin password bootstrap. Used only when no admin password
# is already configured; later in-app password changes are not overwritten.
# VORTNOTES_ADMIN_PASSWORD=
